# MDR Surveillance System — Environment Configuration
# Copy this file to .env and edit values before running.

# Flask
SECRET_KEY=change-this-to-a-random-secret-key-in-production-abc123xyz

# MongoDB
MONGO_URI=mongodb://localhost:27017/mdr_disease_db

# Optional: MongoDB with auth
# MONGO_URI=mongodb://username:password@localhost:27017/mdr_disease_db

# Flask environment
FLASK_ENV=development
FLASK_DEBUG=1

# Email alert settings (Gmail SMTP)
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password
